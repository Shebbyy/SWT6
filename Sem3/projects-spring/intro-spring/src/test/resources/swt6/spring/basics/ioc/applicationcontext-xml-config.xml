<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Variant 1 find dependencies in XML config file -->
    <bean id="fileLogger" class="swt6.spring.basics.ioc.util.FileLogger">
        <property name="fileName" value="out.log"/>
    </bean>
    <bean id="consoleLogger" class="swt6.spring.basics.ioc.util.ConsoleLogger">
        <property name="prefix" value="[V2] "/>
    </bean>

    <bean id="workLogService-setter-injection" class="swt6.spring.basics.ioc.logic.xmlconfig.WorkLogServiceImpl">
        <property name="logger" ref="consoleLogger"/>
    </bean>

    <bean id="workLogService-constructor-injection" class="swt6.spring.basics.ioc.logic.xmlconfig.WorkLogServiceImpl">
        <constructor-arg index="0" ref="fileLogger"/>
    </bean>
</beans>